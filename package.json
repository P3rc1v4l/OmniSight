{
  "name": "omnisight",
  "version": "3.1.9",
  "description": "OmniSight – Dein zentrales Streaming-Hub",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:release": "electron-builder --win --x64 --publish always",
    "make-icon": "node scripts/generate-icons.js",
    "postinstall": "electron-builder install-app-deps",
    "shrinkwrap": "npm shrinkwrap"
  },
  "build": {
    "appId": "com.omnisight.app",
    "productName": "OmniSight",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "generateUpdatesFilesForAllChannels": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmniSight",
      "differentialPackage": true,
      "installerSidebar": null,
      "license": "LICENSE",
      "warningsAsErrors": false
    },
    "publish": {
      "provider": "github",
      "owner": "P3rc1v4l",
      "repo": "OmniSight"
    },
    "afterPack": "./scripts/fuses.js",
    "asar": true,
    "asarUnpack": [
      "node_modules/@electron/fuses/**"
    ],
    "extraMetadata": {
      "certExpiry": "2029-05-23",
      "certExpiryNote": "Self-Signed Zertifikat läuft ab – create-cert.ps1 erneut ausführen",
      "appVersion": "3.1.9"
    },
    "forceCodeSigning": false
  },
  "keywords": [
    "streaming",
    "electron",
    "hub"
  ],
  "author": "P3rc1v4l",
  "license": "PROPRIETARY",
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.4",
    "png-to-ico": "^2.1.8",
    "@electron/fuses": "^1.8.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7"
  }
}