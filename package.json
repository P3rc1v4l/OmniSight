{
  "name": "omnisight",
  "version": "3.2.9",
  "description": "OmniSight \u2013 Dein zentrales Streaming-Hub",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:release": "electron-builder --win --x64 --publish always",
    "make-icon": "node scripts/generate-icons.js",
    "postinstall": "node scripts/fuses.js || true && (npx @castlabs/evs-eas check --skip 2>/dev/null || true)",
    "shrinkwrap": "npm shrinkwrap",
    "bundle": "node scripts/build-bundle.js",
    "prebuild": "node scripts/build-bundle.js",
    "prestart": "node scripts/build-bundle.js"
  },
  "build": {
    "appId": "com.omnisight.app",
    "productName": "OmniSight",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "generateUpdatesFilesForAllChannels": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmniSight",
      "uninstallDisplayName": "OmniSight",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "license": "LICENSE",
      "include": "build/installer.nsh",
      "differentialPackage": true,
      "warningsAsErrors": false,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "P3rc1v4l",
      "repo": "OmniSight"
    },
    "afterPack": "./scripts/fuses.js",
    "asar": true,
    "asarUnpack": [
      "node_modules/@electron/fuses/**"
    ],
    "extraMetadata": {
      "certExpiry": "2029-05-23",
      "certExpiryNote": "Self-Signed Zertifikat l\u00e4uft ab \u2013 create-cert.ps1 erneut ausf\u00fchren",
      "appVersion": "3.2.9"
    },
    "forceCodeSigning": false,
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    }
  },
  "keywords": [
    "streaming",
    "electron",
    "hub"
  ],
  "author": "P3rc1v4l",
  "license": "PROPRIETARY",
  "devDependencies": {
    "electron": "npm:@castlabs/electron-releases@v34.3.0+wv1.2.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.4",
    "png-to-ico": "^2.1.8",
    "@electron/fuses": "^1.8.0",
    "@castlabs/electron-releases": "v34.3.0+wv1.2.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7"
  }
}