{
  "name": "omnisight",
  "version": "1.0.9",
  "description": "OmniSight – Dein zentrales Streaming-Hub",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "make-icon": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "com.omnisight.app",
    "productName": "OmniSight",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "DEIN-GITHUB-USERNAME",
      "repo": "aletheos-stream"
    }
  },
  "keywords": ["streaming","electron","hub"],
  "author": "OmniSight",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.4",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7"
  }
}
