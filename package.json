{
  "name": "omnisight",
  "version": "2.1.0",
  "description": "OmniSight – Dein zentrales Streaming-Hub",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:release": "electron-builder --win --x64 --publish always",
    "make-icon": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "com.omnisight.app",
    "productName": "OmniSight",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmniSight",
      "differentialPackage": false
    },
    "publish": {
      "provider": "github",
      "owner": "P3rc1v4l",
      "repo": "OmniSight",
      "private": true
    },
    "generateUpdatesFilesForAllChannels": false,
    "buildDependenciesFromSource": false,
    "differentialPackage": false
  },
  "keywords": [
    "streaming",
    "electron",
    "hub"
  ],
  "author": "OmniSight",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.33.4",
    "png-to-ico": "^2.1.8"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7"
  }
}