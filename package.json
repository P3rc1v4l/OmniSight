{
  "name": "omnisight",
  "version": "1.0.8",
  "description": "OmniSight – Dein zentrales Streaming-Hub",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.omnisight.app",
    "productName": "OmniSight",
    "directories": { "output": "dist" },
    "win":   { "target": "nsis",     "icon": "src/assets/icon.png" },
    "mac":   { "target": "dmg",      "icon": "src/assets/icon.png" },
    "linux": { "target": "AppImage", "icon": "src/assets/icon.png" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "DEIN-GITHUB-USERNAME",
      "repo": "aletheos-stream"
    }
  },
  "keywords": ["streaming","electron","hub"],
  "author": "OmniSight",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "electron-updater": "^6.1.7"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7"
  }
}
