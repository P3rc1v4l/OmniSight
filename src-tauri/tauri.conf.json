{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniHub",
  "version": "0.2.0",
  "identifier": "com.p3rc1v4l.omnihub",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "OmniHub",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https:; media-src 'self' blob: https: mediastream:; img-src 'self' data: https:; connect-src 'self' https: wss:;"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "nsis": {
      "displayLanguageSelector": false,
      "languages": ["German"],
      "installMode": "perMachine"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/P3rc1v4l/OmniHub/releases/latest/download/latest.json"
      ]
    },
    "window-state": {
      "filename": "window-state.json"
    }
  }
}
