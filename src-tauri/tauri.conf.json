{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmniSight",
  "version": "0.72.1",
  "identifier": "com.p3rc1v4l.omnisight",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmniSight",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self' https://api.github.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Luka Kalinka",
    "copyright": "© 2026 Luka Kalinka. Alle Rechte vorbehalten.",
    "category": "Entertainment",
    "shortDescription": "Zentraler Streaming-Hub",
    "longDescription": "OmniSight bündelt deine Streaming-Dienste in einem Fenster – mit Profilen, Watchlist, Statistiken und TMDB-Metadaten.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["German", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2OEJGRDgxODQ5RUZFOTYKUldTVy9wNkVnZjJMZGhiY3FwakE1a0FLbXVnSnB5V003WnRNU0VmSEs5UVFFM3lZekNHb3hBVHMK",
      "endpoints": [
        "https://github.com/P3rc1v4l/OmniSight/releases/latest/download/latest.json"
      ]
    }
  }
}
